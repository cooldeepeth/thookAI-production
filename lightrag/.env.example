# LightRAG sidecar environment file
# Copy this to .env and fill in your OPENAI_API_KEY
# NOTE: OPENAI_API_KEY is the only secret needed — for embeddings + entity extraction LLM
OPENAI_API_KEY=sk-replace-with-real-key

# Embedding configuration — FROZEN after first document insert
# DO NOT change EMBEDDING_MODEL or EMBEDDING_DIM without full index rebuild
EMBEDDING_BINDING=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536
