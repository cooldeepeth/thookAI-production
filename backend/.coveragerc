[run]
branch = true
concurrency = thread
omit =
    tests/*
    conftest.py
    scripts/*
    venv/*
    .venv/*

[report]
exclude_lines =
    pragma: no cover
    def __repr__
    if __name__ == .__main__
    raise NotImplementedError
    pass
    except ImportError
show_missing = true
precision = 2

[html]
directory = htmlcov
