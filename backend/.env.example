# ThookAI Backend Environment Configuration
# Copy this file to .env and fill in your values
# =============================================

# ===== APP =====
ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=INFO

# ===== DATABASE =====
MONGO_URL=mongodb://localhost:27017
DB_NAME=thook_database
MONGO_MAX_POOL_SIZE=100
MONGO_MIN_POOL_SIZE=10
MONGO_TIMEOUT_MS=5000

# ===== SECURITY =====
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=change_this_to_a_random_64_char_string
JWT_ALGORITHM=HS256
JWT_EXPIRE_DAYS=7
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=your_fernet_key_here
# Comma-separated allowed origins (no wildcards in production!)
CORS_ORIGINS=http://localhost:3000,https://yourdomain.com
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_AUTH_PER_MINUTE=10
# Encryption key for OAuth token storage (generate same way as FERNET_KEY)
ENCRYPTION_KEY=your_encryption_key_here

# ===== LLM PROVIDERS =====
# Emergent Universal Key (supports OpenAI, Anthropic, Google)
EMERGENT_LLM_KEY=your_emergent_key
# Direct provider keys (optional if using Emergent Key)
OPENAI_API_KEY=sk-your_openai_key
ANTHROPIC_API_KEY=sk-ant-your_anthropic_key
GEMINI_API_KEY=your_gemini_key
# Perplexity for Scout Agent research (https://www.perplexity.ai/settings/api)
PERPLEXITY_API_KEY=pplx-your_perplexity_key

# ===== MEDIA & CREATIVE =====
# Image Generation
FAL_KEY=                        # fal.ai — Flux Pro, Seadance, etc. (fal.ai/dashboard)
# Video Generation (optional, feature-gated)
LUMA_API_KEY=                   # Luma Dream Machine (lumalabs.ai/dream-machine/api)
KLING_API_KEY=                  # Kling 2.0 optional (klingai.com/api-reference)
RUNWAY_API_KEY=                 # Runway ML (runwayml.com)
PIKA_API_KEY=                   # Pika Labs (pika.art)
HEYGEN_API_KEY=                 # HeyGen avatar videos (heygen.com)
DID_API_KEY=                    # D-ID talking head videos (d-id.com)
# Voice / TTS (optional, feature-gated)
ELEVENLABS_API_KEY=             # ElevenLabs (elevenlabs.io/app/api-key)
PLAYHT_API_KEY=                 # Play.ht voice (play.ht)
PLAYHT_USER_ID=                 # Play.ht user ID
GOOGLE_TTS_API_KEY=             # Google Text-to-Speech
# Pinecone for persona vector storage (https://app.pinecone.io)
PINECONE_API_KEY=your_pinecone_key
PINECONE_INDEX_NAME=thookai-personas
PINECONE_ENVIRONMENT=us-east-1

# ===== MEDIA STORAGE (Cloudflare R2) =====
# Create R2 bucket at https://dash.cloudflare.com/
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key
R2_BUCKET_NAME=thookai-media
# Public URL prefix for serving files (e.g., pub-xxxx.r2.dev or custom domain)
R2_PUBLIC_URL=https://pub-xxxx.r2.dev

# ===== TASK QUEUE =====
# Redis for Celery background tasks (optional but recommended for video/voice generation)
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ===== BILLING =====
# Stripe for subscriptions and payments (https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_test_your_stripe_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_key
# Webhook secret from Stripe dashboard
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Stripe Price IDs (create in Stripe Dashboard > Products)
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_ANNUAL=
STRIPE_PRICE_STUDIO_MONTHLY=
STRIPE_PRICE_STUDIO_ANNUAL=
STRIPE_PRICE_AGENCY_MONTHLY=
STRIPE_PRICE_AGENCY_ANNUAL=
STRIPE_PRICE_CREDITS_100=
STRIPE_PRICE_CREDITS_500=
STRIPE_PRICE_CREDITS_1000=

# ===== OAUTH =====
# Google OAuth (console.cloud.google.com → APIs & Services → Credentials)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
# Public URL of this API (must match authorized redirect URI in Google Cloud)
BACKEND_URL=http://localhost:8001
# LinkedIn OAuth (linkedin.com/developers)
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
# Meta/Instagram OAuth (developers.facebook.com)
META_APP_ID=
META_APP_SECRET=
# Twitter/X OAuth (developer.twitter.com)
TWITTER_API_KEY=
TWITTER_API_SECRET=

# ===== MONITORING =====
# Sentry for error tracking (optional)
SENTRY_DSN=your_sentry_dsn_optional

# ===== FRONTEND URL =====
# For Stripe redirect URLs and CORS
FRONTEND_URL=http://localhost:3000

# ===== RESEND (transactional email — password reset) =====
# https://resend.com/api-keys
RESEND_API_KEY=
FROM_EMAIL=noreply@thookai.com

# ===== n8n WORKFLOW ORCHESTRATION =====
# n8n replaces Celery beat for scheduled tasks (Phase 9)
N8N_URL=http://n8n:5678
N8N_WEBHOOK_SECRET=your_n8n_webhook_secret_here
N8N_API_KEY=
N8N_BACKEND_CALLBACK_URL=http://backend:8001
# Workflow IDs (populated after creating workflows in n8n UI)
N8N_WORKFLOW_SCHEDULED_POSTS=
N8N_WORKFLOW_RESET_DAILY_LIMITS=
N8N_WORKFLOW_REFRESH_MONTHLY_CREDITS=
N8N_WORKFLOW_CLEANUP_OLD_JOBS=
N8N_WORKFLOW_CLEANUP_EXPIRED_SHARES=
N8N_WORKFLOW_AGGREGATE_DAILY_ANALYTICS=
N8N_WORKFLOW_CLEANUP_STALE_JOBS=

# n8n Docker Compose (development)
N8N_POSTGRES_PASSWORD=n8n_dev_password
N8N_ENCRYPTION_KEY=dev_encryption_key_change_in_prod
N8N_WEBHOOK_URL=http://localhost:5678

# === LightRAG Knowledge Graph Sidecar ===
LIGHTRAG_URL=http://lightrag:9621
LIGHTRAG_API_KEY=                          # Optional: set if LightRAG auth enabled
# FROZEN after first document insert — do NOT change without full index rebuild
LIGHTRAG_EMBEDDING_MODEL=text-embedding-3-small
LIGHTRAG_EMBEDDING_DIM=1536
