# ThookAI Backend Environment Configuration
# Copy this file to .env and fill in your values
# =============================================

# ===== APP =====
ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=INFO

# ===== DATABASE =====
MONGO_URL=mongodb://localhost:27017
DB_NAME=thook_database
MONGO_MAX_POOL_SIZE=100
MONGO_MIN_POOL_SIZE=10
MONGO_TIMEOUT_MS=5000

# ===== SECURITY =====
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=change_this_to_a_random_64_char_string
JWT_ALGORITHM=HS256
JWT_EXPIRE_DAYS=7
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=your_fernet_key_here
# Comma-separated allowed origins (no wildcards in production!)
CORS_ORIGINS=http://localhost:3000,https://yourdomain.com
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_AUTH_PER_MINUTE=10

# ===== LLM PROVIDERS =====
# Emergent Universal Key (supports OpenAI, Anthropic, Google)
EMERGENT_LLM_KEY=your_emergent_key
# Direct provider keys (optional if using Emergent Key)
OPENAI_API_KEY=sk-your_openai_key
ANTHROPIC_API_KEY=sk-ant-your_anthropic_key
GEMINI_API_KEY=your_gemini_key
# Perplexity for Scout Agent research (https://www.perplexity.ai/settings/api)
PERPLEXITY_API_KEY=pplx-your_perplexity_key

# ===== MEDIA & CREATIVE =====
# ElevenLabs for voice synthesis (https://elevenlabs.io/app/settings/api-keys)
ELEVENLABS_API_KEY=your_elevenlabs_key
# Pinecone for persona vector storage (https://app.pinecone.io)
PINECONE_API_KEY=your_pinecone_key
PINECONE_INDEX_NAME=thookai-personas

# ===== MEDIA STORAGE (Cloudflare R2) =====
# Create R2 bucket at https://dash.cloudflare.com/
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key
R2_BUCKET_NAME=thookai-media
# Public URL prefix for serving files (e.g., pub-xxxx.r2.dev or custom domain)
R2_PUBLIC_URL=https://pub-xxxx.r2.dev

# ===== TASK QUEUE =====
# Redis for Celery background tasks (optional but recommended for video/voice generation)
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ===== BILLING =====
# Stripe for subscriptions and payments (https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_test_your_stripe_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_key
# Webhook secret from Stripe dashboard
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Stripe Price IDs (create in Stripe Dashboard > Products)
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_ANNUAL=
STRIPE_PRICE_STUDIO_MONTHLY=
STRIPE_PRICE_STUDIO_ANNUAL=
STRIPE_PRICE_AGENCY_MONTHLY=
STRIPE_PRICE_AGENCY_ANNUAL=
STRIPE_PRICE_CREDITS_100=
STRIPE_PRICE_CREDITS_500=
STRIPE_PRICE_CREDITS_1000=

# ===== OAUTH =====
# Google OAuth for social login (via Emergent)
GOOGLE_CLIENT_ID=your_google_client_id

# ===== MONITORING =====
# Sentry for error tracking (optional)
SENTRY_DSN=your_sentry_dsn_optional

# ===== FRONTEND URL =====
# For Stripe redirect URLs and CORS
FRONTEND_URL=http://localhost:3000
