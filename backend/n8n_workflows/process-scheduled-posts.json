{
  "name": "process-scheduled-posts",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "cronExpression",
              "expression": "*/5 * * * *"
            }
          ]
        }
      },
      "id": "cron-trigger",
      "name": "Cron Trigger",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [250, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{$env.N8N_BACKEND_CALLBACK_URL || 'http://backend:8001'}}/api/n8n/execute/process-scheduled-posts",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "X-ThookAI-Signature",
              "value": "={{require('crypto').createHmac('sha256', $env.N8N_WEBHOOK_SECRET || '').update(JSON.stringify({})).digest('hex')}}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "options": {
          "timeout": 120000,
          "retry": {
            "maxTries": 2,
            "waitBetweenTries": 10000
          }
        }
      },
      "id": "execute-task",
      "name": "Execute Task",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [500, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{$env.N8N_BACKEND_CALLBACK_URL || 'http://backend:8001'}}/api/n8n/callback",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "X-ThookAI-Signature",
              "value": "={{require('crypto').createHmac('sha256', $env.N8N_WEBHOOK_SECRET || '').update(JSON.stringify({workflow_type: 'process-scheduled-posts', status: $json.status || 'completed', result: $json.result || {}, executed_at: new Date().toISOString(), affected_user_ids: ($json.result && $json.result.published_user_ids) ? $json.result.published_user_ids : []})).digest('hex')}}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {"name": "workflow_type", "value": "process-scheduled-posts"},
            {"name": "status", "value": "={{$json.status || 'completed'}}"},
            {"name": "result", "value": "={{JSON.stringify($json.result || {})}}"},
            {"name": "executed_at", "value": "={{new Date().toISOString()}}"},
            {"name": "affected_user_ids", "value": "={{JSON.stringify(($json.result && $json.result.published_user_ids) ? $json.result.published_user_ids : [])}}"}
          ]
        },
        "options": {
          "timeout": 30000
        }
      },
      "id": "callback",
      "name": "Callback",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [750, 300]
    }
  ],
  "connections": {
    "Cron Trigger": {
      "main": [
        [{"node": "Execute Task", "type": "main", "index": 0}]
      ]
    },
    "Execute Task": {
      "main": [
        [{"node": "Callback", "type": "main", "index": 0}]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1"
  }
}
