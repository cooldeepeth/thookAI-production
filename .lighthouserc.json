{
  "ci": {
    "collect": {
      "numberOfRuns": 3,
      "url": [
        "https://thook.ai",
        "https://thook.ai/auth",
        "https://thook.ai/dashboard"
      ],
      "settings": {
        "preset": "desktop",
        "throttlingMethod": "simulate"
      }
    },
    "assert": {
      "assertions": {
        "categories:performance": ["error", { "minScore": 0.9 }],
        "categories:accessibility": ["warn", { "minScore": 0.85 }]
      }
    },
    "upload": {
      "target": "filesystem",
      "outputDir": ".lighthouseci"
    }
  }
}
